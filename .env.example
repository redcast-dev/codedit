# AI Provider API Keys
# Copy this file to .env and add your actual API keys

# OpenAI (ChatGPT)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude)
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (Gemini)
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Groq (Fast inference)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Default AI Provider (openai, anthropic, google, groq)
# Claude Sonnet is set as the default for best coding performance
VITE_DEFAULT_AI_PROVIDER=anthropic

# Default Model Names
VITE_OPENAI_MODEL=gpt-4-turbo-preview
VITE_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
VITE_GOOGLE_MODEL=gemini-1.5-pro
VITE_GROQ_MODEL=llama-3.1-70b-versatile
